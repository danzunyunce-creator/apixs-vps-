# ============================================================
# APIXS LIVE — .gitignore (hardened)
# ============================================================

# Dependencies
node_modules/
backend/node_modules/

# Build output — NEVER commit compiled artifacts
dist/
dist-ssr/
backend/dist/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Sensitive data
.env
.env.local
.env.production
backend/.env
backend/streamflow.db
backend/streamflow.db-shm
backend/streamflow.db-wal
backend/streamflow.db*

# Large / generated user content
backend/uploads/
backend/bin/
backend/thumbnails/
uploads/

# Lock files (let VPS generate its own)
package-lock.json
backend/package-lock.json
yarn.lock

# Debug & one-off scripts (never commit these)
backend/check_progress.js
backend/diag_optimize.js
backend/diagnostic.js
backend/list_all_videos.js
backend/test-path.js
backend/migrate_db.js
backend/debug_db.js
backend/scripts/cleanup_storage.js
scripts/cleanup_storage.js
monitor.cjs
tmp/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
